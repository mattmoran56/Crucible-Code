{
  "name": "codecrucible",
  "version": "0.1.0",
  "description": "IDE for agentic development",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-vite build && electron-builder --dir && rm -rf \"/Applications/Crucible Code.app\" && mv \"/Applications/mac-arm64/Crucible Code.app\" \"/Applications/Crucible Code.app\" && rm -rf /Applications/mac-arm64",
    "mock": "node node_modules/vite/bin/vite.js --config mock/vite.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "screenshots": "npx tsx scripts/capture-screenshots.ts"
  },
  "build": {
    "appId": "com.codecrucible.app",
    "productName": "Crucible Code",
    "asar": false,
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "/Applications"
    },
    "icon": "resources/icon.icns",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "fix-path": "^5.0.0",
    "marked": "^17.0.5",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.0.2",
    "simple-git": "^3.27.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^8.0.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^5.0.0",
    "playwright": "^1.59.1",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  }
}
